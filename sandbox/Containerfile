# Erdtree tier sandbox — a Rocky 9 container that runs the full agent stack in
# OS isolation, now with a seeded home playground and real hardware telemetry
# (GPU / CPU / sensors / fans) passed through from the host for testing.
#
# Destructive ops still hit the disposable overlay, not the host (the repo is
# mounted read-only; host disks aren't writable). Inference is delegated to the
# host's GPU-backed Ollama over loopback (--network=host).
FROM quay.io/rockylinux/rockylinux:9

# Sysadmin + hardware-inspection binaries so the agent's tools and raw bash have
# real commands: process/disk/file tools, PCI listing, CPU info, and lm_sensors
# (reads the host /sys/class/hwmon passed in at run time -> fan/temp/voltage).
RUN dnf -y install \
        python3.11 python3.11-pip \
        iproute procps-ng util-linux findutils shadow-utils \
        firewalld systemd \
        lm_sensors pciutils usbutils dmidecode hostname which \
        tree jq vim-minimal \
    && dnf clean all

# Optional docs/RAG backend. The CORE agent imports none of this (degrades OFF).
RUN python3.11 -m pip install --no-cache-dir sqlite-vec==0.1.9 || true

# Seed playground -> /root (the home you land in). Writable in the overlay, so
# you can create / edit / delete during testing; it all resets on exit (--rm).
COPY seed/home/ /root/

ENV ERDTREE_BASE_URL=http://localhost:11434 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/opt/erdtree
WORKDIR /root
CMD ["/usr/bin/python3.11", "-m", "shell.shell"]
